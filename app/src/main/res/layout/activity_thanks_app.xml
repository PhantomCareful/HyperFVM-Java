<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <eightbitlab.com.blurview.BlurTarget
        android:id="@+id/target"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:ignore="MissingConstraints">

        <com.careful.HyperFVM.utils.ForDesign.Animation.SpringBackScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:clipChildren="false"
            android:clipToPadding="false"
            tools:ignore="UselessParent">

            <LinearLayout
                android:id="@+id/CoContributorTeam_Container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="10dp"
                android:paddingTop="120dp"
                android:paddingBottom="50dp"
                android:orientation="vertical"
                android:clipChildren="false"
                android:clipToPadding="false">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="?attr/ImportantCardViewBackground"
                    app:cardCornerRadius="20dp">

                    <LinearLayout
                        android:id="@+id/data_images_index_update_info_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:clickable="true"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_heart"
                            app:tint="?attr/VectorGraphicColorOnImportantCardView"
                            tools:ignore="ContentDescription" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="?attr/TextViewColorOnImportantCardView"
                                android:text="@string/title_about_app_thanks_list"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="?attr/TextViewColorOnImportantCardView"
                                android:text="@string/label_thanks_list_app_top"
                                android:textSize="15sp" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/thanks_list_container_app_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="25dp"
                    app:cardBackgroundColor="?attr/GeneralCardViewBackground"
                    app:cardCornerRadius="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- 第1个选项：miuix -->
                        <LinearLayout
                            android:id="@+id/thanks_list_container_app_1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="16dp"
                            android:clickable="true"
                            android:background="?attr/selectableItemBackground">

                            <!-- 右侧箭头 -->
                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_github"
                                app:tint="?attr/VectorGraphicColorOnGeneralCardView"
                                tools:ignore="ContentDescription" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="16dp"
                                android:gravity="center_vertical">

                                <!-- 左侧文字 -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_thanks_list_app_1_1"
                                    android:textColor="?attr/TextViewColorOnGeneralCardView"
                                    android:textSize="20sp"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_thanks_list_app_1_2"
                                    android:textColor="?attr/TextViewColorOnGeneralCardView"
                                    android:textSize="15sp"/>

                            </LinearLayout>

                            <!-- 右侧箭头 -->
                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="?attr/VectorGraphicColorOnGeneralCardView"
                                tools:ignore="ContentDescription" />

                        </LinearLayout>

                        <!-- 第2个选项：HyperCeiler -->
                        <LinearLayout
                            android:id="@+id/thanks_list_container_app_2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="16dp"
                            android:clickable="true"
                            android:background="?attr/selectableItemBackground">

                            <!-- 右侧箭头 -->
                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_github"
                                app:tint="?attr/VectorGraphicColorOnGeneralCardView"
                                tools:ignore="ContentDescription" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="16dp"
                                android:gravity="center_vertical">

                                <!-- 左侧文字 -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_thanks_list_app_2_1"
                                    android:textColor="?attr/TextViewColorOnGeneralCardView"
                                    android:textSize="20sp"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_thanks_list_app_2_2"
                                    android:textColor="?attr/TextViewColorOnGeneralCardView"
                                    android:textSize="15sp"/>

                            </LinearLayout>

                            <!-- 右侧箭头 -->
                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="?attr/VectorGraphicColorOnGeneralCardView"
                                tools:ignore="ContentDescription" />

                        </LinearLayout>

                        <!-- 第3个选项：模糊材质 -->
                        <LinearLayout
                            android:id="@+id/thanks_list_container_app_3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="16dp"
                            android:clickable="true"
                            android:background="?attr/selectableItemBackground">

                            <!-- 右侧箭头 -->
                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_github"
                                app:tint="?attr/VectorGraphicColorOnGeneralCardView"
                                tools:ignore="ContentDescription" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="16dp"
                                android:gravity="center_vertical">

                                <!-- 左侧文字 -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_thanks_list_app_3_1"
                                    android:textColor="?attr/TextViewColorOnGeneralCardView"
                                    android:textSize="20sp"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_thanks_list_app_3_2"
                                    android:textColor="?attr/TextViewColorOnGeneralCardView"
                                    android:textSize="15sp"/>

                            </LinearLayout>

                            <!-- 右侧箭头 -->
                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="?attr/VectorGraphicColorOnGeneralCardView"
                                tools:ignore="ContentDescription" />

                        </LinearLayout>

                        <!-- 第4个选项：数据图查看器 -->
                        <LinearLayout
                            android:id="@+id/thanks_list_container_app_4"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="16dp"
                            android:clickable="true"
                            android:background="?attr/selectableItemBackground">

                            <!-- 右侧箭头 -->
                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_github"
                                app:tint="?attr/VectorGraphicColorOnGeneralCardView"
                                tools:ignore="ContentDescription" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="16dp"
                                android:gravity="center_vertical">

                                <!-- 左侧文字 -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_thanks_list_app_4_1"
                                    android:textColor="?attr/TextViewColorOnGeneralCardView"
                                    android:textSize="20sp"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_thanks_list_app_4_2"
                                    android:textColor="?attr/TextViewColorOnGeneralCardView"
                                    android:textSize="15sp"
                                    tools:ignore="TooManyViews" />

                            </LinearLayout>

                            <!-- 右侧箭头 -->
                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="?attr/VectorGraphicColorOnGeneralCardView"
                                tools:ignore="ContentDescription" />

                        </LinearLayout>

                        <!-- 第5个选项：ScrollView -->
                        <LinearLayout
                            android:id="@+id/thanks_list_container_app_5"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="16dp"
                            android:clickable="true"
                            android:background="?attr/selectableItemBackground">

                            <!-- 右侧箭头 -->
                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_wechat"
                                app:tint="?attr/VectorGraphicColorOnGeneralCardView"
                                tools:ignore="ContentDescription" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="16dp"
                                android:gravity="center_vertical">

                                <!-- 左侧文字 -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_thanks_list_app_5_1"
                                    android:textColor="?attr/TextViewColorOnGeneralCardView"
                                    android:textSize="20sp"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_thanks_list_app_5_2"
                                    android:textColor="?attr/TextViewColorOnGeneralCardView"
                                    android:textSize="15sp"
                                    tools:ignore="TooManyViews" />

                            </LinearLayout>

                            <!-- 右侧箭头 -->
                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="?attr/VectorGraphicColorOnGeneralCardView"
                                tools:ignore="ContentDescription" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </com.careful.HyperFVM.utils.ForDesign.Animation.SpringBackScrollView>

    </eightbitlab.com.blurview.BlurTarget>

    <!-- 状态栏渐变遮罩层 -->
    <View
        android:id="@+id/status_bar_gradient"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@drawable/status_bar_gradient_no_title"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/FloatButton_Back_Container"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="40dp"
        android:layout_marginStart="10dp"
        app:strokeWidth="0dp"
        app:cardCornerRadius="40dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent">

        <eightbitlab.com.blurview.BlurView
            android:id="@+id/blurViewButtonBack"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:blurOverlayColor="@color/blur_overlay_color">

            <ImageButton
                android:id="@+id/FloatButton_Back"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:backgroundTint="@android:color/transparent"
                android:src="@drawable/ic_arrow_left"
                android:stateListAnimator="@null"
                android:clickable="false"
                app:elevation="0dp"
                app:pressedTranslationZ="0dp"
                app:rippleColor="@android:color/transparent"
                tools:ignore="ContentDescription" />

        </eightbitlab.com.blurview.BlurView>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>