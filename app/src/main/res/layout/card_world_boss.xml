<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="HardcodedText,ButtonStyle">

    <androidx.cardview.widget.CardView
        android:id="@+id/card_world_boss_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:visibility="gone"
        android:clickable="true"
        app:cardBackgroundColor="?attr/colorErrorContainer"
        app:cardCornerRadius="20dp">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_marginBottom="70dp"
            android:alpha="0.2"
            android:adjustViewBounds="true"
            android:src="@drawable/dashboard_world_boss"
            android:scaleType="fitCenter"
            android:layout_gravity="end|bottom"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:clickable="false"
            android:background="?attr/selectableItemBackground"
            android:padding="10dp">

            <TextView
                android:id="@+id/dashboard_WorldBoss_Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:textColor="?attr/colorOnErrorContainer"
                android:textSize="25sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/dashboard_WorldBoss_Content_Detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnErrorContainer"
                android:textStyle="bold"
                android:textSize="20sp"/>

            <!-- 水平线段 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginVertical="16dp"
                android:background="?attr/colorOnError"/>

            <TextView
                android:id="@+id/dashboard_WorldBoss_Content_Status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:textColor="?attr/colorOnErrorContainer"
                android:textStyle="bold"
                android:textSize="20sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal"
                android:clipChildren="false"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/dashboard_WorldBoss_Content_Status_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:gravity="center"
                        android:textColor="?attr/colorOnErrorContainer"
                        android:textStyle="bold"
                        android:textSize="15sp"/>

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/dashboard_WorldBoss_LinearProgressIndicator_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:indeterminate="false"
                        app:trackStopIndicatorSize="10dp"
                        app:trackThickness="20dp"
                        app:indicatorColor="?attr/colorError"
                        app:trackColor="?attr/colorOnError"
                        app:trackCornerRadius="20dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/dashboard_WorldBoss_Content_Status_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:gravity="center"
                        android:textColor="?attr/colorOnErrorContainer"
                        android:textStyle="bold"
                        android:textSize="15sp"/>

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/dashboard_WorldBoss_LinearProgressIndicator_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:indeterminate="false"
                        app:trackStopIndicatorSize="10dp"
                        app:trackThickness="20dp"
                        app:indicatorColor="?attr/colorError"
                        app:trackColor="?attr/colorOnError"
                        app:trackCornerRadius="20dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/dashboard_WorldBoss_Content_Status_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:gravity="center"
                        android:textColor="?attr/colorOnErrorContainer"
                        android:textStyle="bold"
                        android:textSize="15sp"/>

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/dashboard_WorldBoss_LinearProgressIndicator_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:indeterminate="false"
                        app:trackStopIndicatorSize="10dp"
                        app:trackThickness="20dp"
                        app:indicatorColor="?attr/colorError"
                        app:trackColor="?attr/colorOnError"
                        app:trackCornerRadius="20dp"/>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="-6dp"
                android:orientation="horizontal"
                android:clipChildren="false"
                android:clipToPadding="false">

                <Button
                    android:id="@+id/button_action_1"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:padding="0dp"
                    android:text="赛季规则"
                    android:textSize="20sp"
                    android:textColor="?attr/colorOnError"
                    app:backgroundTint="?attr/colorError"
                    app:cornerRadius="25dp" />

                <Button
                    android:id="@+id/button_action_2"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:padding="0dp"
                    android:text="赛季奖励"
                    android:textSize="20sp"
                    android:textColor="?attr/colorOnError"
                    app:backgroundTint="?attr/colorError"
                    app:cornerRadius="25dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</merge>