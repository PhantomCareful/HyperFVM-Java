<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        android:id="@+id/dashboard_HappyHoliday_Container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_columnWeight="1"
        android:layout_marginBottom="10dp"
        app:cardBackgroundColor="?attr/GeneralCardViewBackground"
        app:cardCornerRadius="20dp">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="5dp"
            android:alpha="0.2"
            android:adjustViewBounds="true"
            android:src="@drawable/dashboard_happy_holiday_image"
            android:scaleType="fitXY"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"
            android:clickable="false"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp"
                android:text="@string/title_dashboard_happy_holiday"
                android:textColor="?attr/TextViewColorOnGeneralCardView"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/dashboard_HappyHoliday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/TextViewColorOnGeneralCardView"
                android:textSize="20sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</merge>