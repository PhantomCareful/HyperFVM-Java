<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/Tools_Pad"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:baselineAligned="false"
        android:orientation="horizontal"
        tools:ignore="MissingConstraints,UselessParent">

        <com.careful.HyperFVM.utils.ForDesign.Animation.SpringBackScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="100dp">

                <ImageView
                    android:id="@+id/about_app_icon"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:src="@drawable/app_icon_in"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textSize="40sp"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_gravity="center"/>

                <TextView
                    android:id="@+id/version_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/version_info"
                    android:textSize="20sp"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_gravity="center"/>

                <TextView
                    android:id="@+id/label_check_update"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_check_update"
                    android:textSize="20sp"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_gravity="center"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="15dp"
                    android:text="@string/label_developer"
                    android:textSize="20sp"
                    android:textColor="?attr/colorOnSurface"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="5dp"
                    card_view:cardCornerRadius="20dp"
                    card_view:cardBackgroundColor="?attr/colorPrimary">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="10dp"
                        android:clickable="true"
                        android:background="?attr/selectableItemBackground">

                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="2"
                            android:rowCount="1">

                            <ImageView
                                android:id="@+id/Image_View_Phantom_Careful"
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:adjustViewBounds="true"
                                android:scaleType="fitStart"
                                android:src="@drawable/phantom_careful"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/developer_name"
                                android:textSize="25sp"
                                android:textColor="?attr/colorOnPrimary"
                                android:layout_marginStart="20dp"
                                android:gravity="start|center_vertical"
                                android:layout_gravity="center_vertical"/>

                        </GridLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="15dp"
                    android:text="@string/label_thanks"
                    android:textSize="20sp"
                    android:textColor="?attr/colorOnSurface"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="5dp"
                    card_view:cardCornerRadius="20dp"
                    card_view:cardBackgroundColor="?attr/colorPrimaryContainer">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/about_app_thanks_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/many_n"
                            android:textSize="20sp"
                            android:textColor="?attr/colorOnPrimaryContainer"
                            android:padding="10dp"
                            android:clickable="true"
                            android:background="?attr/selectableItemBackground"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </com.careful.HyperFVM.utils.ForDesign.Animation.SpringBackScrollView>

        <com.careful.HyperFVM.utils.ForDesign.Animation.SpringBackScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="100dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:text="@string/label_more"
                    android:textSize="20sp"
                    android:textColor="?attr/colorOnSurface"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginBottom="10dp"
                    card_view:cardCornerRadius="20dp"
                    card_view:cardBackgroundColor="?attr/colorPrimaryContainer">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/text_about_app_github"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/label_about_app_github"
                            android:textSize="20sp"
                            android:textColor="?attr/colorOnPrimaryContainer"
                            android:padding="10dp"
                            android:clickable="true"
                            android:background="?attr/selectableItemBackground"/>

                        <TextView
                            android:id="@+id/text_about_app_get_update_123pan"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/label_about_app_get_update_123pan"
                            android:textSize="20sp"
                            android:textColor="?attr/colorOnPrimaryContainer"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp"
                            android:clickable="true"
                            android:background="?attr/selectableItemBackground"/>

                        <TextView
                            android:id="@+id/text_about_app_see_update_log_history"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/label_about_app_see_update_log_history"
                            android:textSize="20sp"
                            android:textColor="?attr/colorOnPrimaryContainer"
                            android:padding="10dp"
                            android:clickable="true"
                            android:background="?attr/selectableItemBackground"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </com.careful.HyperFVM.utils.ForDesign.Animation.SpringBackScrollView>

    </LinearLayout>

</LinearLayout>