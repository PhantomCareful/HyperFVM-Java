<?xml version="1.0" encoding="utf-8"?>
<!-- 主容器：左侧导航 + 右侧内容（含ToolBar和Fragment） -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 1. 左侧导航栏（Material You 风格） -->
    <com.google.android.material.navigationrail.NavigationRailView
        android:id="@+id/left_nav_view"
        android:layout_width="80dp"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface"
        app:itemIconSize="30dp"
        app:itemIconTint="@color/nav_icon_tint"
        app:itemTextAppearance="@style/NavItemTextStyle"
        app:itemTextColor="@color/nav_text_tint"
        app:menu="@menu/bottom_nav_menu"/>

    <!-- 2. 右侧内容区域（ToolBar + Fragment） -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/right_content_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="80dp">

        <!-- 2.1 顶部ToolBar（提升层级） -->
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/right_app_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurface"
            android:fitsSystemWindows="true"
            android:gravity="center_horizontal"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/Top_AppBar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                app:titleTextColor="?attr/colorOnSurface"
                app:titleTextAppearance="@style/ToolBarTitleStyle" />

        </com.google.android.material.appbar.AppBarLayout>

        <!-- 2.2 Fragment容器（贴在ToolBar下方） -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/nav_host_fragment_activity_main"
            android:name="androidx.navigation.fragment.NavHostFragment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_behavior="@string/appbar_scrolling_view_behavior"
            app:defaultNavHost="true"
            app:navGraph="@navigation/mobile_navigation"/>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>